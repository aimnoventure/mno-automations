# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000
  
# ── Monday.com — Achora ─────────────────────────────────────────────────────────
MONDAY_API_KEY_ACHORA=
MONDAY_WEBHOOK_SECRET_ACHORA=
MONDAY_BOARD_ID_ACHORA=5025223094

# ── Monday.com — Maple ──────────────────────────────────────────────────────────
MONDAY_API_KEY_MAPLE=
MONDAY_WEBHOOK_SECRET_MAPLE=
MONDAY_BOARD_ID_MAPLE=5027083317

# ── WordPress — Maple ───────────────────────────────────────────────────────────
# Site URL with no trailing slash (e.g. https://maplecommunity.com.au)
WP_URL_MAPLE=
# WordPress application username (not your login username)
WP_USERNAME_MAPLE=
# WordPress application password — generate under Users → Profile → Application Passwords
WP_APP_PASSWORD_MAPLE=

# ── WordPress — Achora ──────────────────────────────────────────────────────────
# Site URL with no trailing slash (e.g. https://achora.com.au)
WP_URL_ACHORA=
# WordPress application username (not your login username)
WP_USERNAME_ACHORA=
# WordPress application password — generate under Users → Profile → Application Passwords
WP_APP_PASSWORD_ACHORA=

# ── Campaign Monitor — Achora ───────────────────────────────────────────────────
# API key from Campaign Monitor account → Account Settings → API Keys
CAMPAIGN_MONITOR_API_KEY_ACHORA=

# ── Monday.com Newsletter Board — Achora ────────────────────────────────────────
# Secret for the newsletter board webhook (board 5026304080) — separate from content board
MONDAY_NEWSLETTER_WEBHOOK_SECRET_ACHORA=

# ── AI Providers ────────────────────────────────────────────────────────────────
# Used for OpenAI agent (gpt-4o), JSON cleaning (gpt-4o-mini), and RAG embeddings
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase (RAG / Vector Store) ───────────────────────────────────────────────
# Use the service role key — the anon key does not have permission to call RPCs
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── PostgreSQL (Document Metadata) ──────────────────────────────────────────────
# Full connection string, e.g. postgresql://user:password@host:5432/dbname
POSTGRES_CONNECTION_STRING=

# ── Google Docs — Newsletter Output ─────────────────────────────────────────────
# OAuth2 credentials — create a Desktop app OAuth2 client in Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Run `node scripts/get-google-refresh-token.js` once to obtain this value
GOOGLE_OAUTH_REFRESH_TOKEN=
# Google Drive folder ID where newsletter docs will be created
GOOGLE_DRIVE_NEWSLETTER_FOLDER_ID_ACHORA=
