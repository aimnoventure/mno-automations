# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000
  
# ── Monday.com — Achora ─────────────────────────────────────────────────────────
MONDAY_API_KEY_ACHORA=
MONDAY_WEBHOOK_SECRET_ACHORA=
MONDAY_BOARD_ID_ACHORA=5025223094

# ── Monday.com — Maple ──────────────────────────────────────────────────────────
MONDAY_API_KEY_MAPLE=
MONDAY_WEBHOOK_SECRET_MAPLE=
MONDAY_BOARD_ID_MAPLE=5027083317

# ── WordPress — Maple ───────────────────────────────────────────────────────────
# Site URL with no trailing slash (e.g. https://maplecommunity.com.au)
WP_URL_MAPLE=
# WordPress application username (not your login username)
WP_USERNAME_MAPLE=
# WordPress application password — generate under Users → Profile → Application Passwords
WP_APP_PASSWORD_MAPLE=

# ── WordPress — Achora ──────────────────────────────────────────────────────────
# Site URL with no trailing slash (e.g. https://achora.com.au)
WP_URL_ACHORA=
# WordPress application username (not your login username)
WP_USERNAME_ACHORA=
# WordPress application password — generate under Users → Profile → Application Passwords
WP_APP_PASSWORD_ACHORA=

# ── AI Providers ────────────────────────────────────────────────────────────────
# Used for OpenAI agent (gpt-4o), JSON cleaning (gpt-4o-mini), and RAG embeddings
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase (RAG / Vector Store) ───────────────────────────────────────────────
# Use the service role key — the anon key does not have permission to call RPCs
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── PostgreSQL (Document Metadata) ──────────────────────────────────────────────
# Full connection string, e.g. postgresql://user:password@host:5432/dbname
POSTGRES_CONNECTION_STRING=
